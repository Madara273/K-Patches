+					 * 802.3→802.11 encapsulation.
+					 */
+					if (cdp_tx_non_std(data_soc, tx_vdev_id,
+							   OL_TX_SPEC_RAW, nbuf) != NULL) {
+						/* nbuf was not consumed — TX failed */
+						qdf_nbuf_free(nbuf);
+						hdd_inject_err("CDP raw data TX rejected for vdev %u",
