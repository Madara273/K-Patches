From 9e0ffcb8c31eda5d334a27d061dcad6a1e6237bd Mon Sep 17 00:00:00 2001
From: Madara273 <ravenhoxs@gmail.com>
Date: Sat, 22 Feb 2025 19:59:06 +0000
Subject: [PATCH 04/14] MPTCP -- tcp: move RST on ABORT according to RFC793 to
 the header file

Signed-off-by: Madara273 <ravenhoxs@gmail.com>
---
 include/net/tcp.h | 2 +-
 net/ipv4/tcp.c    | 9 ---------
 2 files changed, 1 insertion(+), 10 deletions(-)

diff --git a/include/net/tcp.h b/include/net/tcp.h
index bb6f5c099082..b02bec2c7b49 100644
--- a/include/net/tcp.h
+++ b/include/net/tcp.h
@@ -428,7 +428,7 @@ static inline bool tcp_need_reset(int state)
 {
 	return (1 << state) &
 	       (TCPF_ESTABLISHED | TCPF_CLOSE_WAIT | TCPF_FIN_WAIT1 |
-		TCPF_FIN_WAIT2 | TCPF_SYN_RECV);
+		TCPF_FIN_WAIT2 | TCPF_SYN_RECV | TCPF_SYN_SENT);
 }
 
 int __must_check tcp_queue_rcv(struct sock *sk, struct sk_buff *skb,
diff --git a/net/ipv4/tcp.c b/net/ipv4/tcp.c
index ed2fd20a74df..a4c8672d56e2 100644
--- a/net/ipv4/tcp.c
+++ b/net/ipv4/tcp.c
@@ -2650,15 +2650,6 @@ void tcp_close(struct sock *sk, long timeout)
 }
 EXPORT_SYMBOL(tcp_close);
 
-/* These states need RST on ABORT according to RFC793 */
-
-static inline bool tcp_need_reset(int state)
-{
-	return (1 << state) &
-	       (TCPF_ESTABLISHED | TCPF_CLOSE_WAIT | TCPF_FIN_WAIT1 |
-		TCPF_FIN_WAIT2 | TCPF_SYN_RECV | TCPF_SYN_SENT);
-}
-
 static void tcp_rtx_queue_purge(struct sock *sk)
 {
 	struct rb_node *p = rb_first(&sk->tcp_rtx_queue);
-- 
